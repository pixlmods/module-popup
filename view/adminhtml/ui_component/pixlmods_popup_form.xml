<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">
                pixlmods_popup_form.pixlmods_popup_form_data_source
            </item>
            <item name="component" xsi:type="string">
                PixlMods_Popup/js/form/form
            </item>
        </item>
        <item name="template" xsi:type="string">
            templates/form/collapsible
        </item>
    </argument>

    <settings>
        <buttons>
            <button name="save" class="PixlMods\Popup\Block\Adminhtml\Edit\SaveButton"/>
            <button name="delete" class="PixlMods\Popup\Block\Adminhtml\Edit\DeleteButton"/>
            <button name="back" class="PixlMods\Popup\Block\Adminhtml\Edit\BackButton"/>
        </buttons>
        <namespace>pixlmods_popup_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>pixlmods_popup_form.pixlmods_popup_form_data_source</dep>
        </deps>
    </settings>

    <dataSource name="pixlmods_popup_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">
                    Magento_Ui/js/form/provider
                </item>
            </item>
        </argument>
        <settings>
            <submitUrl path="*/*/save"/>
        </settings>
        <dataProvider class="PixlMods\Popup\Ui\DataProvider\Form\DataProvider" name="pixlmods_popup_form_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general">
        <settings>
            <label translate="true">General</label>
        </settings>
        <field name="entity_id" formElement="hidden">
            <settings>
                <dataType>text</dataType>
            </settings>
        </field>
        <field name="title" sortOrder="10" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>true</visible>
                <label translate="true">Title</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="content" formElement="wysiwyg" sortOrder="20">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">popup</item>
                    <item name="wysiwyg" xsi:type="boolean">true</item>
                    <item name="wysiwygConfigData" xsi:type="array">
                        <item name="is_pagebuilder_enabled" xsi:type="boolean">false</item>
                        <item name="add_variables" xsi:type="boolean">false</item>
                        <item name="add_widgets" xsi:type="boolean">false</item>
                        <item name="add_images" xsi:type="boolean">true</item>
                        <item name="add_directives" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Content</label>
                <dataScope>content</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <additionalClasses>
                    <class name="admin__field-small">true</class>
                </additionalClasses>
            </settings>
        </field>
        <field name="status" sortOrder="30" formElement="select">
            <settings>
                <dataType>text</dataType>
                <visible>true</visible>
                <label translate="true">Status</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="PixlMods\Popup\Model\Source\Status"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="start_date" sortOrder="40" formElement="date">
            <settings>
                <dataType>text</dataType>
                <visible>true</visible>
                <label translate="true">Start Date</label>
            </settings>
            <formElements>
                <date>
                    <settings>
                        <options>
                            <option name="timeFormat" xsi:type="string">h:mm:ss A</option>
                            <option name="dateFormat" xsi:type="string">MMM d, YYYY</option>
                            <option name="showsTime" xsi:type="boolean">false</option>
                        </options>
                    </settings>
                </date>
            </formElements>
        </field>
        <field name="end_date" sortOrder="50" formElement="date">
            <settings>
                <dataType>text</dataType>
                <visible>true</visible>
                <label translate="true">End Date</label>
            </settings>
            <formElements>
                <date>
                    <settings>
                        <options>
                            <option name="timeFormat" xsi:type="string">h:mm:ss A</option>
                            <option name="dateFormat" xsi:type="string">MMM d, YYYY</option>
                            <option name="showsTime" xsi:type="boolean">false</option>
                        </options>
                    </settings>
                </date>
            </formElements>
        </field>
        <field name="pages" sortOrder="60" formElement="multiselect">
            <settings>
                <dataType>text</dataType>
                <label translate="true">CMS Pages</label>
                <dataScope>pages</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <multiselect>
                    <settings>
                        <options class="PixlMods\Popup\Model\Source\FrontendPages"/>
                    </settings>
                </multiselect>
            </formElements>
        </field>
        <field name="customer_group_ids" sortOrder="70" formElement="multiselect">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Customer Groups</label>
                <dataScope>customer_group_ids</dataScope>
                <notice translate="true">Leave empty to display to all customer groups.</notice>
            </settings>
            <formElements>
                <multiselect>
                    <settings>
                        <options class="PixlMods\Popup\Model\Source\CustomerGroups"/>
                    </settings>
                </multiselect>
            </formElements>
        </field>
        <field name="stores" sortOrder="70" formElement="multiselect">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>number</dataType>
                <label translate="true">Websites</label>
                <dataScope>stores</dataScope>
            </settings>
            <formElements>
                <multiselect>
                    <settings>
                        <options class="Magento\Cms\Ui\Component\Listing\Column\Cms\Options"/>
                    </settings>
                </multiselect>
            </formElements>
        </field>
    </fieldset>
</form>
